# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# These are throwaway TESTNET demo identities — the UI signs with them
# directly so the stage demo has no wallet-extension dependency.

VITE_RPC_URL=https://soroban-testnet.stellar.org:443
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# From deployments.json at the repo root
VITE_CONTRACT_ID=

# stellar keys show alice   (funder + registry admin demo account)
VITE_FUNDER_SECRET=

# stellar keys show mallory (second funder for the multi-funder demo)
VITE_FUNDER2_SECRET=

# stellar keys show farmer1 (Mang Ramon — primary farmer demo account)
VITE_FARMER_SECRET=

# Second farmer (Aling Nena) — View-as switch in the farmer app
VITE_FARMER2_SECRET=

# oracle/.env ORACLE_SECRET — powers the in-app "typhoon" demo button.
# The real signer is oracle/sign-event.js; this is the same key, surfaced
# in the UI purely so the stage demo is clickable end to end.
VITE_ORACLE_SECRET=
