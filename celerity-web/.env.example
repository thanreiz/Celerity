# Copy to .env and fill in. NEVER commit .env (it is gitignored).
#
# PUBLIC (safe in the Vite browser bundle — VITE_ prefix):
VITE_RPC_URL=https://soroban-testnet.stellar.org:443
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# From deployments.json at the repo root
VITE_CONTRACT_ID=

# SERVER-ONLY secrets (NO VITE_ prefix — used by /api/* on Vercel and vite dev middleware).
# These never ship in the JS bundle. The browser unlocks them with DEMO_GATE.
FUNDER_SECRET=
FUNDER2_SECRET=
FARMER_SECRET=
FARMER2_SECRET=
ORACLE_SECRET=

# Stage PIN — required header X-Celerity-Gate for /api/invoke and /api/oracle-sign.
# Pick a strong PIN for production; share only with presenters.
DEMO_GATE=

# Optional local fallback: if FUNDER_SECRET is empty, the API also accepts
# legacy VITE_FUNDER_SECRET etc. Do NOT set VITE_*_SECRET in Vercel Production.
